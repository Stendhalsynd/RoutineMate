# Firebase project
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_STORAGE_BUCKET=your-firebase-project-id.firebasestorage.app
FIREBASE_APP_ID=your-web-app-id
FIREBASE_MEASUREMENT_ID=your-measurement-id

# Firebase admin SDK
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Web client SDK
NEXT_PUBLIC_FIREBASE_API_KEY=your-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-firebase-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-firebase-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-web-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Expo / React Native client SDK
EXPO_PUBLIC_FIREBASE_API_KEY=your-android-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-firebase-project-id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-firebase-project-id.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-android-app-id

# Google auth
GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=your-google-android-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-google-android-client-id.apps.googleusercontent.com

# Notion source databases (required until Firestore cutover completes)
NOTION_TOKEN=your-notion-internal-integration-token
NOTION_DB_SESSIONS=your-notion-sessions-db-id
NOTION_DB_MEALS=your-notion-meals-db-id
NOTION_DB_WORKOUTS=your-notion-workouts-db-id
NOTION_DB_BODY_METRICS=your-notion-body-metrics-db-id
NOTION_DB_GOALS=your-notion-goals-db-id

# Optional Notion source databases
NOTION_DB_MEAL_TEMPLATES=your-notion-meal-templates-db-id
NOTION_DB_WORKOUT_TEMPLATES=your-notion-workout-templates-db-id
NOTION_DB_REMINDER_SETTINGS=your-notion-reminder-settings-db-id
